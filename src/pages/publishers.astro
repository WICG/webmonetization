---
import { getLangFromUrl, useTranslations } from '../i18n/utils'
import Base from '../layouts/Base.astro'
import {
  heroContent,
  publisherTags,
  toolsContent,
  walletConnectionContent,
  wordPressPluginContent,
} from '../data/publishers.ts'
import AudienceHero from '../components/pages/AudienceHero.astro'
import HowItWorks from '../components/pages/HowItWorks.astro'
import SplitLayout from '../components/pages/SplitLayout.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<Base
  title={t('pages.publishers.title')}
  description={t('pages.publishers.description')}
>
  <AudienceHero content={heroContent} pills={publisherTags} />
  <HowItWorks>
    <p>
      To receive Web Monetization payments, you'll need an account with a
      compatible digital wallet provider. Once you have your wallet address, use
      the <a
        href='/tools/link-tag/'
        data-umami-event='Publisher page link - Link tag generator'
        >link generator</a
      > tool to create a Web Monetization <code>&lt;link&gt;</code> element and add
      it to each page you want to monetize. Visitors with the Web Monetization browser
      extension can then stream payments to you at a rate and frequency they choose,
      or send you one-time-support.
    </p>
  </HowItWorks>
  <SplitLayout content={walletConnectionContent}>
    <p>
      Monetizing your website has never been easier. Use your wallet address
      with the link tag generator to create a <link /> element and add it to each
      page you want to monetize.
    </p>
  </SplitLayout>
  <SplitLayout content={toolsContent}>
    <p>
      Let your audience know they can finally support you in the best way
      possible. Use our custom-made tools to signal it. They’re user-friendly,
      visually appealing, and require no coding.
    </p>
  </SplitLayout>
  <SplitLayout content={wordPressPluginContent}>
    <p>
      Start earning from your WordPress content using our new Web Monetization
      plugin, built for an open web experience with no paywalls and no hassle.
      Just add your wallet, pick what to monetize, and you're ready to collect
      in minutes.
    </p>
    <p>One simple plugin. No coding needed. Privacy respected.</p>
  </SplitLayout>
</Base>
